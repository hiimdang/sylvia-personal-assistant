# Copy this file to .env and fill in your real values.
# All values below are placeholders.

SYLVIA_DEFAULT_MODEL=gpt-4.1-mini
SYLVIA_IMAGE_DESCRIPTION_MODEL=gpt-4.1-mini
SYLVIA_KEYWORD_EXTRACTION_MODEL=gpt-4.1-nano
SYLVIA_IMAGE_KEYWORD_EXTRACTION_MODEL=gpt-4.1-nano
SYLVIA_RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
SYLVIA_EMBEDDING_MODEL=intfloat/multilingual-e5-small
SYLVIA_EMBEDDING_DIM=384
SYLVIA_COLLECTION_NAME=sylvia_dataset
SYLVIA_BATCH_SIZE=50
SYLVIA_ENABLE_INTERACTION_LOG=false
# Optional: only used when interaction logging is enabled
# SYLVIA_LOG_FILE=response.jsonl
SYLVIA_TEMPERATURE=0.3
SYLVIA_MEMORY_WINDOW_SIZE=4

SYLVIA_LLM_PROVIDER_TYPE=openai
SYLVIA_EMBEDDING_PROVIDER_TYPE=fastembed
SYLVIA_VECTOR_STORE_PROVIDER_TYPE=qdrant
SYLVIA_SEARCH_PROVIDER_TYPE=brave

SYLVIA_QDRANT_URL=https://your-qdrant-instance-url
SYLVIA_QDRANT_API_KEY=your_qdrant_api_key
SYLVIA_BRAVE_SEARCH_API_KEY=your_brave_search_api_key
SYLVIA_GOOGLE_API_KEY=your_google_custom_search_api_key
SYLVIA_GOOGLE_CSE_ID=your_google_custom_search_engine_id

# Non-prefixed variable consumed by OpenAI SDK/LangChain
OPENAI_API_KEY=your_openai_api_key

# Optional: path to a private persona prompt override file
# SYLVIA_PERSONA_PROMPT_FILE=sylvia_core/prompts/sylvia_persona_prompt.private.py
